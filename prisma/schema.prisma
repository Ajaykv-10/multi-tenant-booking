generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  role      Role     @default(CUSTOMER)

  // 🔥 Role Relation
  roleId    String?
  accessRole AccessRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  // 🔥 Provider Staff Relation
  providerId String?
  provider   Provider? @relation("ProviderStaff", fields: [providerId], references: [id])

  // 🔥 Provider Owner Relation (1:1)
  ownedProvider Provider? @relation("ProviderOwner")

  // 🔥 Customer bookings
  bookings  Booking[]

  createdAt DateTime @default(now())
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique

  providers Provider[]
}

model Provider {
  id          String   @id @default(cuid())
  name        String

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  // 🔥 OWNER
  ownerId     String   @unique
  owner       User     @relation("ProviderOwner", fields: [ownerId], references: [id])

  // 🔥 STAFF
  users       User[]   @relation("ProviderStaff")

  roleId      String?
  accessRole  AccessRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  resources   Resource[]
  bookings    Booking[]

  createdAt   DateTime @default(now())
}

model Resource {
  id          String   @id @default(cuid())
  name        String
  type        ResourceType @default(EVENT)
  status      ResourceStatus @default(DRAFT)

  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])

  duration    Int
  price       Int

  capacity    Int      @default(1)
  isGroupBookingEnabled Boolean @default(false)
  maxBookingPerUser     Int?

  startTime   String
  endTime     String

  bookings     Booking[]
  customFields ResourceCustomField[]
}

enum ResourceType {
  EVENT
  HOTEL
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
}

enum CustomFieldType {
  short_text
  description
}

model ResourceCustomField {
  id          String          @id @default(cuid())
  resourceId  String
  resource    Resource        @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  label       String          @db.VarChar(100)
  type        CustomFieldType
  placeholder String?         @db.VarChar(150)
  value       String?
  isRequired  Boolean         @default(false)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([resourceId, order])
  @@index([resourceId])
}

model Booking {
  id          String   @id @default(cuid())

  userId      String
  resourceId  String
  providerId  String

  start       DateTime
  end         DateTime

  status      BookingStatus @default(CONFIRMED)
  seats       Int           @default(1)

  // 🔥 Invoice fields
  invoiceNumber      String?   @unique
  invoiceGeneratedAt DateTime?

  user        User     @relation(fields: [userId], references: [id])
  resource    Resource @relation(fields: [resourceId], references: [id])
  provider    Provider @relation(fields: [providerId], references: [id])
  participants Participant[]

  createdAt   DateTime @default(now())
}

// Atomic per-year invoice sequence counter
model InvoiceCounter {
  year     Int @id
  sequence Int @default(0)
}

model Participant {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?

  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])

  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  PROVIDER
  CUSTOMER
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

model AccessRole {
  id          String      @id @default(uuid())
  name        String      @unique @db.VarChar(60)
  description String?     @db.Text
  scope       RoleScope
  permissions Json        // Array of strings ["module.action"]
  isSystem    Boolean     @default(false)
  
  users       User[]
  providers   Provider[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum RoleScope {
  ADMIN
  PROVIDER
}